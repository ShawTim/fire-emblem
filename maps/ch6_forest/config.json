  "turnEvents": [
    {
      "turn": 2,
      "type": "dialogue",
      "text": [
        {
          "speaker": "rex",
          "text": "（指向碼頭遠處的旗艦）那艘黑帆船——是巴爾薩提督的『海狼號』。船尾有帝國旗，但船頭掛的是私旗。"
        },
        {
          "speaker": "cain",
          "text": "私旗？提督不是帝國正規軍嗎？"
        },
        {
          "speaker": "rex",
          "text": "他是。但他同時與三支海盜團簽了密約。莫爾甘默許這種勾當——因為港口的補給對北境帝國軍很關鍵。"
        },
        {
          "speaker": "thor",
          "text": "提督勾結海盜？嘁，這算什麼帝國軍人。"
        },
        {
          "speaker": "fran",
          "text": "（看向遠方）……奇怪，那艘『海狼號』的桅杆上有魔法陣的痕跡。是用來定位星印的儀器嗎？"
        },
        {
          "speaker": "eirine",
          "text": "莫爾甘已經把獵捕星印的網撒到海上了。馬庫斯——加快推進，奪下指揮所。"
        }
      ]
    },
    {
      "turn": 3,
      "type": "recruit",
      "text": [
        {
          "speaker": null,
          "text": "南方天際飛來一頭白鬃天馬——騎士的鎧甲已破，斗篷上滿是煙灰。"
        },
        {
          "speaker": "natasha",
          "text": "（俯衝著陸）反抗軍！請收留我——我是來自南方自由城邦『艾爾梅拉』的天馬騎士那塔莎！"
        },
        {
          "speaker": "natasha",
          "text": "三天前——莫爾甘的軍隊夷平了我的城邦。守軍三百人、市民兩千人——全部……全部沒了。"
        },
        {
          "speaker": "eirine",
          "text": "（震驚）夷平……整座城邦？！"
        },
        {
          "speaker": "natasha",
          "text": "莫爾甘下了命令：『艾爾梅拉與艾爾法利亞通謀，視同叛逆，雞犬不留』。理由是——三十年前我們收留過艾爾法利亞的逃難民。"
        },
        {
          "speaker": "marcus",
          "text": "（沉默良久）……三十年前那一波難民裡，就有臣下的妹妹。她當時就是嫁去艾爾梅拉的。"
        },
        {
          "speaker": "natasha",
          "text": "（看著馬庫斯）……將軍，您的妹妹是叫艾蓮娜嗎？她是我母親的好友。她……她也在那三天前。"
        },
        {
          "speaker": "marcus",
          "text": "……（深吸一口氣，扶住長槍）……知道了。謝謝妳告訴我。"
        },
        {
          "speaker": "eirine",
          "text": "那塔莎，從今天起，這支隊伍就是妳的歸宿。馬庫斯，這份仇——我們一起算。"
        },
        {
          "speaker": "natasha",
          "text": "公主殿下……謝謝。讓臣為艾爾梅拉的兩千名亡魂——舉這支槍。"
        }
      ]
    },
    {
      "turn": 4,
      "type": "reinforce",
      "text": [
        {
          "speaker": null,
          "text": "港口東側竄出帝國援軍，碼頭旁也躲出一群手持砍刀的海盜。"
        },
        {
          "speaker": "lina",
          "text": "東邊援軍三人——交給我。"
        },
        {
          "speaker": "natasha",
          "text": "（騎乘天馬升空）海盜由臣下從上方壓制。馬庫斯，臣下護您的右翼。"
        }
      ],
      "enemies": [
        {
          "classId": "soldier",
          "level": 10,
