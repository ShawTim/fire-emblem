  "turnEvents": [
    {
      "turn": 1,
      "type": "dialogue",
      "text": [
        {
          "speaker": null,
          "text": "神殿深處傳來祭司長ザルバ的咒語聲——每念一句，神殿的翡翠石柱便黯淡一分。"
        },
        {
          "speaker": "fran",
          "text": "（手指顫抖）……他已經念到第三段咒文了。每段需要兩個時辰——意味著他四個時辰前就開始了。"
        },
        {
          "speaker": "helga",
          "text": "（指向側殿）祭司軍團的部署——左翼是亡靈先鋒，中央是暗法師護陣，右翼是反射護盾。臣下知道弱點。"
        },
        {
          "speaker": "rex",
          "text": "（駕飛龍俯衝偵察）祭壇上方有一道封閉式法陣——進不去。必須從正門推進。"
        },
        {
          "speaker": "eirine",
          "text": "馬庫斯、ヘルガ前鋒。法蘭與莉娜遠程壓制。雷克斯切斷後援。全員出擊！"
        }
      ]
    },
    {
      "turn": 2,
      "type": "dialogue",
      "text": [
        {
          "speaker": null,
          "text": "祭壇方向傳來ザルバ尖銳的笑聲。"
        },
        {
          "speaker": "ザルバ",
          "text": "（遠處的聲音）公主殿下——您終於來了。本祭司等的就是這一刻。"
        },
        {
          "speaker": "ザルバ",
          "text": "莫爾甘大人說過——星印的覺醒儀式需要一個『活祭』。公主殿下，您剛好趕上了。"
        },
        {
          "speaker": "helga",
          "text": "（咬牙）ザルバ——你把我師團的士兵變成亡靈，現在又要拿公主獻祭？！"
        },
        {
          "speaker": "ザルバ",
          "text": "（笑）ヘルガ副將，您師團的小兵——本祭司用得很順手。他們現在是『暗黑之門』儀式的『燃料』。"
        },
        {
          "speaker": "natasha",
          "text": "（壓抑怒火）……拿活人當燃料的祭司——這片大陸不能容下他。"
        },
        {
          "speaker": "thor",
          "text": "嘁——說那麼多廢話。老子的大斧告訴他什麼叫『活祭』。"
        }
      ]
    },
    {
      "turn": 3,
      "type": "dialogue",
      "text": [
        {
          "speaker": "helga",
          "text": "（小聲對艾琳）公主，臣下要說一件事——ザルバ的反射護盾有一個盲點。每念完一段咒文，他必須抬頭看星——那五秒護盾會降下。"
        },
        {
          "speaker": "eirine",
          "text": "五秒……夠莉娜射一箭。"
        },
        {
          "speaker": "lina",
          "text": "（拉弓瞄準）……三段咒文之間的間隔不固定。但我能聽聲音。ヘルガ，咒語結尾的音節是什麼？"
        },
        {
          "speaker": "helga",
          "text": "結尾是『コルガ・モーラ』——拖長的兩個音節。"
        },
        {
          "speaker": "lina",
          "text": "（半閉眼睛）記住了。下次他念到那兩個音節——我的箭就出去。"
        },
        {
          "speaker": "marcus",
          "text": "（眼神讚許）……莉娜，你父王教你射箭的時候，他知道有一天你會替公主救命。"
        }
      ]
    },
    {
      "turn": 4,
      "type": "reinforce",
      "text": [
        {
          "speaker": null,
          "text": "祭壇後方的暗門打開，更多被腐化的師團亡靈湧出——它們的鎧甲上還繡著鐵壁軍團的徽記。"
        },
        {
          "speaker": "helga",
          "text": "（眼眶泛紅）……那些都是我的兵。對不起——讓你們再死一次。但今天，是讓你們真正安息的一次。"
        },
        {
          "speaker": "serra",
          "text": "（合掌念禱）ヘルガ姊，我會為他們念往生咒。每一個倒下的亡靈——都會聽見我的祈禱。"
        },
        {
          "speaker": "olivier",
          "text": "（小聲）……臣下從來沒見過這麼悲傷的戰場。"
        }
      ],
      "enemies": [
        {
          "classId": "skeleton",
          "level": 12,
