  "villageEvents": [
    {
      "x": 6,
      "y": 7,
      "reward": { "type": "item", "id": "vulnerary" },
      "dialogue": [
        { "speaker": null, "text": "村民從屋內探出頭來。" },
        { "speaker": null, "text": "「你哋係嚟救我哋㗎！呢支傷藥俾你哋，希望幫得到手。」" }
      ]
    },
    {
      "x": 3,
      "y": 1,
      "reward": { "type": "item", "id": "vulnerary" },
      "dialogue": [
        { "speaker": null, "text": "屋裡傳出顫抖嘅聲音。" },
        { "speaker": null, "text": "「魔法兵差啲燒咗成間屋⋯⋯多謝你哋。呢支傷藥俾返你。」" }
      ]
    },
    {
      "x": 14,
      "y": 1,
      "reward": { "type": "item", "id": "steelSword" },
      "dialogue": [
        { "speaker": null, "text": "「你哋竟然打到呢度⋯⋯我祖父留低嘅鋼劍，俾你哋。一定要打敗佢哋。」" }
      ]
    },
    {
      "x": 1,
      "y": 4,
      "reward": { "type": "item", "id": "vulnerary" },
      "dialogue": [
        { "speaker": null, "text": "「謝謝你打跑佢！呢支傷藥我留咗好耐，俾你哋啦。」" }
      ]
    },
    {
      "x": 16,
      "y": 4,
      "reward": { "type": "item", "id": "javelin" },
      "dialogue": [
        { "speaker": null, "text": "「呢支標槍係我阿爸留低嘅。我用唔到，你哋攞去啦。」" }
      ]
    },
    {
      "x": 16,
      "y": 9,
      "reward": { "type": "item", "id": "handAxe" },
      "dialogue": [
        { "speaker": null, "text": "「家人都收咗喺地窖度。呢支手斧，攞去用啦。」" }
      ]
    },
    {
      "x": 8,
      "y": 10,
      "reward": { "type": "item", "id": "vulnerary" },
      "dialogue": [
        { "speaker": null, "text": "「我老竇話呢間屋以前係驛站。剩低呢樽傷藥，俾你哋啦。」" }
      ]
    }
  ],
