  "villageEvents": [
    {
      "x": 6,
      "y": 7,
      "reward": { "type": "item", "id": "vulnerary" },
      "dialogue": [
        { "speaker": null, "text": "村民從屋內探出頭來。" },
        { "speaker": null, "text": "「你哋係嚟救我哋㗎！呢支傷藥俾你哋，希望幫得到手。」" }
      ]
    },
    {
      "x": 3,
      "y": 1,
      "reward": { "type": "item", "id": "vulnerary" },
      "dialogue": [
        { "speaker": null, "text": "屋裡傳出顫抖嘅聲音。" },
        { "speaker": null, "text": "「魔法兵差啲燒咗成間屋⋯⋯多謝你哋。呢支傷藥俾返你。」" }
      ]
    },
    {
      "x": 14,
      "y": 1,
      "reward": { "type": "item", "id": "steelSword" },
      "dialogue": [
        { "speaker": null, "text": "「你哋竟然打到呢度⋯⋯我祖父留低嘅鋼劍，俾你哋。一定要打敗佢哋。」" }
      ]
    },
    {
      "x": 1,
      "y": 4,
      "reward": { "type": "item", "id": "vulnerary" },
      "dialogue": [
        { "speaker": null, "text": "「謝謝你打跑佢！呢支傷藥我留咗好耐，俾你哋啦。」" }
      ]
    },
    {
      "x": 16,
      "y": 4,
      "reward": { "type": "item", "id": "javelin" },
      "dialogue": [
        { "speaker": null, "text": "「呢支標槍係我阿爸留低嘅。我用唔到，你哋攞去啦。」" }
      ]
    },
    {
      "x": 16,
      "y": 9,
      "reward": { "type": "item", "id": "handAxe" },
      "dialogue": [
        { "speaker": null, "text": "「家人都收咗喺地窖度。呢支手斧，攞去用啦。」" }
      ]
    },
    {
      "x": 8,
      "y": 10,
      "reward": { "type": "item", "id": "vulnerary" },
      "dialogue": [
        { "speaker": null, "text": "「我老竇話呢間屋以前係驛站。剩低呢樽傷藥，俾你哋啦。」" }
      ]
    }
  ],
  "turnEvents": [
    {
      "turn": 1,
      "type": "recruit",
      "text": [
        {
          "speaker": null,
          "text": "索爾與瑟拉加入隊伍。"
        },
        {
          "speaker": "marcus",
          "text": "村莊已經陷入火海，帝國兵正喺各處搶掠。"
        },
        {
          "speaker": "eirine",
          "text": "我哋要趕喺佢哋燒嗮啲屋之前救人。"
        }
      ]
    },
    {
      "turn": 2,
      "type": "reinforce",
      "text": [
        {
          "speaker": "thor",
          "text": "公主，那幫躲在房子裡放冷箭的，老子先去把他們挖出來！"
        },
        {
          "speaker": "serra",
          "text": "托爾，慢一點！你方才中的那一斧傷口還在流血！"
        },
        {
          "speaker": "marcus",
          "text": "托爾，掩護左翼村屋。莉娜的弓會幫你壓制屋頂的弓兵。"
        },
        {
          "speaker": "thor",
          "text": "嘁，又是這種戰術話。算了，老子先把那邊清乾淨。"
        },
        {
          "speaker": "eirine",
          "text": "賽拉留在馬庫斯身邊接應傷者。其他人，跟我推進中央指揮點。"
        },
        {
          "speaker": null,
          "text": "村莊南北兩端的小巷竄出帝國增援。"
        }
      ],
      "enemies": [
        {
          "classId": "soldier",
          "level": 5,
          "x": 1,
          "y": 11,
          "items": [
            "ironLance"
          ],
          "ai": "aggressive",
          "name": "帝國增援"
        },
        {
          "classId": "soldier",
          "level": 5,
          "x": 16,
          "y": 11,
          "items": [
            "ironLance"
          ],
          "ai": "aggressive",
          "name": "帝國增援"
        }
      ]
    },
    {
      "turn": 4,
      "type": "dialogue",
      "text": [
        {
          "speaker": "serra",
          "text": "公主殿下……剛才那個帝國兵，他臨死前還在喊一個女孩的名字。"
        },
        {
          "speaker": "eirine",
          "text": "賽拉……我知道。每殺一個人，就有一個家庭破碎。"
        },
        {
          "speaker": "thor",
          "text": "別自責了，公主。如果今天不打他們，明天就是村裡的孩子被砍。是他們先選擇了當帝國的爪牙。"
        },
        {
          "speaker": "marcus",
          "text": "戰爭沒有不流血的勝利。臣明白殿下的心情——但今天必須贏。"
        },
        {
          "speaker": "lina",
          "text": "（拉弓瞄向村口）……人，我母親也曾是這樣死的。公主，我幫您扛這份重量。"
        },
        {
          "speaker": "eirine",
          "text": "……謝謝，大家。前進——奪回指揮點。"
        }
      ]
    },
    {
      "turn": 3,
      "type": "reinforce",
      "enemies": [
        {
          "classId": "soldier",
          "level": 5,
          "x": 15,
          "y": 4,
          "items": [
            "ironLance"
          ],
          "ai": "aggressive",
          "name": "帝國增援"
        }
      ]
    },
    {
      "turn": 5,
      "type": "recruit",
      "text": [
        {
          "speaker": null,
          "text": "帝國百夫長高聲喝令，後軍壓上。"
        },
        {
          "speaker": "thor",
          "text": "撐住！再守幾回合就有機會撤離。"
        }
      ]
    },
    {
      "turn": 6,
      "type": "reinforce",
      "enemies": [
        {
          "classId": "knight",
          "level": 7,
          "x": 9,
          "y": 0,
          "items": [
            "steelLance"
          ],
          "ai": "defensive",
          "name": "帝國近衛"
        }
      ]
    }
  ],
  "dialogues": {},
  "bossLines": {
    "opening": "燒這種小村莊是公務。公主殿下若要妨礙公務，便是叛逆。",
    "mid": "嘖——居然真有人為了這種破村子拼命？",
    "death": "報告……上頭……北境……不穩……"
  },
